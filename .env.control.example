# Control machine example env

ARANEAE_ENV=production

# RabbitMQ container credentials on control machine
RABBITMQ_USERNAME=replace-with-rabbitmq-user
RABBITMQ_PASSWORD=replace-with-rabbitmq-strong-password

# Control service
CONTROL_HTTP_PORT=8180
CONTROL_GRPC_PORT=9190
CONTROL_DB_PATH=/data/control.db
ARTIFACT_ROOT=/data/artifacts
INIT_ADMIN_PASSWORD=replace-with-strong-admin-password
CONTROL_JWT_SECRET=replace-with-long-random-jwt-secret
EXECUTION_CALLBACK_KEY=replace-with-long-random-shared-key
CONTROL_NODE_VERIFY_SCHEME=https

# gRPC TLS (recommended for production)
# Set true to enable TLS on control gRPC server.
CONTROL_GRPC_TLS_ENABLED=true
# Required when CONTROL_GRPC_TLS_ENABLED=true
CONTROL_GRPC_TLS_CERT_FILE=/data/certs/control-grpc.crt
CONTROL_GRPC_TLS_KEY_FILE=/data/certs/control-grpc.key
# Optional: set CA to require and verify client certificates (mTLS)
CONTROL_GRPC_TLS_CLIENT_CA_FILE=

# Frontend build-time API target (browser-visible URL)
# Use a real IP/domain reachable by users, not localhost unless only local access is needed.
FRONT_VITE_BACKEND_BASE_URL=https://<control-host-or-domain>
FRONT_VITE_API_FLAVOR=go

# CORS for frontend origins
CONTROL_CORS_ALLOW_ORIGINS=https://<frontend-host-or-domain>

# Optional explicit rabbit URL for control service
# CONTROL_RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/

# Optional: BasaltPass OAuth + identity synchronization
# BASALTPASS_ENABLED=true
# BASALTPASS_BASE_URL=https://<basaltpass-host>
# BASALTPASS_INTERNAL_BASE_URL=http://basaltpass:8101
# BASALTPASS_CLIENT_ID=your-araneae-client-id
# BASALTPASS_CLIENT_SECRET=your-araneae-client-secret
# BASALTPASS_REDIRECT_URI=https://<control-host-or-domain>/api/auth/basaltpass/callback/
# BASALTPASS_SCOPES=openid profile email
# BASALTPASS_ROLE_CLAIM_KEYS=roles,role,app_roles
# BASALTPASS_GROUP_CLAIM_KEYS=groups,group,teams,team
# BASALTPASS_TEAM_SYNC_ENABLED=true
# BASALTPASS_TEAM_SYNC_PRUNE=false
# BASALTPASS_TEAM_PREFIX=Basalt::
