# Control node environment example
# Copy to /etc/araneae/control.env (or your own path) and replace placeholders.

CONTROL_HTTP_ADDR=:8180
CONTROL_GRPC_ADDR=0.0.0.0:9190

CONTROL_DB_PATH=/var/lib/araneae/control.db
ARTIFACT_ROOT=/var/lib/araneae/artifacts

RABBITMQ_URL=amqp://guest:guest@RABBITMQ_HOST:5672/
RABBITMQ_EXCHANGE=tasks.direct

CONTROL_JWT_SECRET=REPLACE_WITH_LONG_RANDOM_SECRET
EXECUTION_CALLBACK_KEY=REPLACE_WITH_SHARED_CALLBACK_KEY
