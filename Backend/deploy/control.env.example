# Control node environment example
# Copy to /etc/araneae/control.env (or your own path) and replace placeholders.

CONTROL_HTTP_ADDR=:8180
CONTROL_GRPC_ADDR=0.0.0.0:9190

CONTROL_DB_PATH=/var/lib/araneae/control.db
ARTIFACT_ROOT=/var/lib/araneae/artifacts

RABBITMQ_URL=amqp://guest:guest@RABBITMQ_HOST:5672/
RABBITMQ_EXCHANGE=tasks.direct

CONTROL_JWT_SECRET=REPLACE_WITH_LONG_RANDOM_SECRET
EXECUTION_CALLBACK_KEY=REPLACE_WITH_SHARED_CALLBACK_KEY

# Optional: BasaltPass OAuth + identity synchronization
# BASALTPASS_OAUTH_ENABLED=true
# BASALTPASS_BASE_URL=http://basaltpass:8101
# BASALTPASS_INTERNAL_BASE_URL=http://basaltpass:8101
# BASALTPASS_OAUTH_CLIENT_ID=your-client-id
# BASALTPASS_OAUTH_CLIENT_SECRET=your-client-secret
# BASALTPASS_OAUTH_REDIRECT_URI=https://control.example.com/api/auth/basaltpass/callback/
# BASALTPASS_OAUTH_SCOPE=openid profile email
# BASALTPASS_ROLE_CLAIM_KEYS=roles,role,app_roles
# BASALTPASS_GROUP_CLAIM_KEYS=groups,group,teams,team
# BASALTPASS_TEAM_SYNC_ENABLED=true
# BASALTPASS_TEAM_SYNC_PRUNE=false
# BASALTPASS_TEAM_PREFIX=Basalt::
