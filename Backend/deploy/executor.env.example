# Executor node environment example
# Copy to /etc/araneae/executor.env (or your own path) and replace placeholders.
# For multiple executors, keep CONTROL_* and callback key aligned,
# and choose queue strategy by EXECUTOR_QUEUE.

EXECUTOR_HTTP_ADDR=:4280

EXECUTOR_DB_PATH=/var/lib/araneae/executor.db
EXECUTOR_WORKDIR=/var/lib/araneae/workdir

# Node auth key used for executor HTTP auth and control gRPC auth.
# If EXECUTOR_NODE_KEY is empty, executor generates one at startup,
# persists to EXECUTOR_NODE_KEY_FILE, and logs the key file path.
EXECUTOR_NODE_KEY=
EXECUTOR_NODE_KEY_FILE=/var/lib/araneae/executor.node.key

RABBITMQ_URL=amqp://guest:guest@RABBITMQ_HOST:5672/
RABBITMQ_EXCHANGE=tasks.direct

# Queue strategy:
# 1) Dedicated node: use unique queue per node, e.g. node-a, node-b
# 2) Load balance: multiple executors share one queue value
EXECUTOR_QUEUE=node-a

# Address of control node, reachable from this executor host.
CONTROL_GRPC_TARGET=CONTROL_PRIVATE_IP:9190
CONTROL_HTTP_BASE=http://CONTROL_PRIVATE_IP:8180

# Must match control EXECUTION_CALLBACK_KEY.
EXECUTION_CALLBACK_KEY=REPLACE_WITH_SHARED_CALLBACK_KEY

# Sink forwarding to HashSlip
EXECUTOR_SINK_ENABLED=true
EXECUTOR_SINK_STRICT=false
EXECUTOR_SINK_DIRNAME=.araneae/sink
HASHSLIP_BASE_URL=http://HASHSLIP_HOST:8106
HASHSLIP_TIMEOUT_SECONDS=15
HASHSLIP_TIMESERIES_PATH=/api/v1/timeseries/records
HASHSLIP_TEXT_PATH=/api/v1/text/records
HASHSLIP_STRUCTURED_PATH=/api/v1/data

# Optional: get service token from BasaltPass for HashSlip calls
# BASALTPASS_TOKEN_URL=http://basaltpass:8101/api/v1/oauth/token
# BASALTPASS_OAUTH_CLIENT_ID=your-client-id
# BASALTPASS_OAUTH_CLIENT_SECRET=your-client-secret
# BASALTPASS_S2S_SCOPE=hashslip.write
