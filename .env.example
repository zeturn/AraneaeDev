# Araneae local configuration (.env)
# Project port assignment (07):
# - ControlNode API: 8107
# - Frontend: 5109
# - ExecutionNode host mapping: 4107

# Core
DJANGO_SECRET_KEY=replace-me-with-a-secure-key
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
ARANEAE_MODE=prod
ARANEAE_MANAGE_BOOTSTRAP=False
INIT_ADMIN_USERNAME=admin
INIT_ADMIN_EMAIL=admin@example.com
INIT_ADMIN_PASSWORD=change-me

# Django security baseline
DJANGO_SECURE_SSL_REDIRECT=True
DJANGO_SESSION_COOKIE_SECURE=True
DJANGO_CSRF_COOKIE_SECURE=True
DJANGO_SECURE_HSTS_SECONDS=31536000
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=True
DJANGO_SECURE_HSTS_PRELOAD=True
# If behind reverse proxy / ingress:
# DJANGO_SECURE_PROXY_SSL_HEADER_NAME=HTTP_X_FORWARDED_PROTO
# DJANGO_SECURE_PROXY_SSL_HEADER_VALUE=https

# URLs
FRONTEND_BASE_URL=http://localhost:5109
CONTROLNODE_BASE_URL=http://localhost:8107
VITE_BACKEND_BASE_URL=http://localhost:8107

# OAuth (BasaltPass)
BASALTPASS_BASE_URL=http://localhost:8101
BASALTPASS_ENABLED=true
BASALTPASS_DISCOVERY_URL=http://localhost:8101/api/v1/.well-known/openid-configuration
BASALTPASS_CLIENT_ID=your-araneae-client-id
BASALTPASS_CLIENT_SECRET=your-araneae-client-secret
BASALTPASS_REDIRECT_URI=http://localhost:8107/api/auth/basaltpass/callback/
BASALTPASS_SCOPES=openid profile email offline_access
BASALTPASS_FRONTEND_CALLBACK_PATH=/oauth/callback

# Security
ARANEAE_CALLBACK_SHARED_SECRET=replace-with-long-random-secret
ARANEAE_NODE_API_TOKEN=replace-with-node-api-token
ARANEAE_ALLOW_INSECURE_CALLBACKS=False

# RabbitMQ
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=replace-with-rabbitmq-username
RABBITMQ_PASSWORD=replace-with-rabbitmq-strong-password
RABBITMQ_VHOST=/

# DB paths (optional)
DJANGO_DB_PATH=/data/db.sqlite3
EXECUTION_DB_PATH=/data/db.sqlite

# Cloud DB (preferred for server deployments; when set, these override the local sqlite paths above)
# DJANGO_DATABASE_URL=postgresql://user:password@db-host:5432/araneae
# EXECUTION_DATABASE_URL=postgresql://user:password@db-host:5432/araneae_execution
