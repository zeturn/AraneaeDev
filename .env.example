# Araneae local configuration (.env)
# Project port assignment (07):
# - ControlNode API: 8107
# - Frontend: 5109
# - ExecutionNode host mapping: 4107

# Core
DJANGO_SECRET_KEY=replace-me-with-a-secure-key
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
INIT_ADMIN_USERNAME=admin
INIT_ADMIN_EMAIL=admin@example.com
INIT_ADMIN_PASSWORD=change-me

# URLs
FRONTEND_BASE_URL=http://localhost:5109
CONTROLNODE_BASE_URL=http://localhost:8107
VITE_BACKEND_BASE_URL=http://localhost:8107

# OAuth (BasaltPass)
BASALTPASS_BASE_URL=http://localhost:8101
BASALTPASS_OAUTH_ENABLED=true
BASALTPASS_OAUTH_DISCOVERY_URL=http://localhost:8101/api/v1/.well-known/openid-configuration
BASALTPASS_OAUTH_CLIENT_ID=your-araneae-client-id
BASALTPASS_OAUTH_CLIENT_SECRET=your-araneae-client-secret
BASALTPASS_OAUTH_REDIRECT_URI=http://localhost:8107/api/auth/basaltpass/callback/
BASALTPASS_OAUTH_SCOPE=openid profile email offline_access
BASALTPASS_FRONTEND_CALLBACK_PATH=/oauth/callback

# Security
ARANEAE_CALLBACK_SHARED_SECRET=replace-with-long-random-secret
ARANEAE_NODE_API_TOKEN=replace-with-node-api-token

# RabbitMQ
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=araneae
RABBITMQ_PASSWORD=araneae
RABBITMQ_VHOST=/

# DB paths (optional)
DJANGO_DB_PATH=/data/db.sqlite3
EXECUTION_DB_PATH=/data/db.sqlite
