# Example environment variables for local development
# Copy to `.env` and fill in real values. Do NOT commit real secrets.

# Django
SECRET_KEY=replace-me-with-a-secure-key
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (example for sqlite or use DATABASE_URL for url-based)
# DATABASE_URL=sqlite:///./ControlNode/db.sqlite3

# Celery / broker (如果使用 RabbitMQ，将通过 config.json 构建，无需在此设置)
# CELERY_BROKER_URL=amqp://user:pass@host:5672/
# CELERY_RESULT_BACKEND=rpc://

# 可选：覆盖 config.json 中的 RabbitMQ 配置（不建议与生产混用）
# RABBITMQ_HOST=localhost
# RABBITMQ_PORT=5672
# RABBITMQ_USERNAME=guest
# RABBITMQ_PASSWORD=
# RABBITMQ_VHOST=/

# 可选：覆盖 Django SECRET_KEY
# DJANGO_SECRET_KEY=

# Other
# EXAMPLE_API_KEY=yourapikey

