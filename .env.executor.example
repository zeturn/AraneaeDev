# Executor machine example env

ARANEAE_ENV=production

# Must point to the shared RabbitMQ reachable from this executor machine
EXECUTOR_RABBITMQ_URL=amqp://<rabbit-user>:<rabbit-pass>@<control-or-rabbit-host>:5672/

# Must point to control machine addresses reachable from this executor machine
EXECUTOR_CONTROL_GRPC_TARGET=<control-host-or-domain>:9190
EXECUTOR_CONTROL_HTTP_BASE=https://<control-host-or-domain>

# gRPC TLS to control (recommended for production)
EXECUTOR_CONTROL_GRPC_TLS_ENABLED=true
# Server certificate verification name (required in production when TLS enabled)
EXECUTOR_CONTROL_GRPC_TLS_SERVER_NAME=<control-host-or-domain>
# Optional custom CA bundle for control gRPC cert verification
EXECUTOR_CONTROL_GRPC_TLS_CA_FILE=
# Optional client certificate for mTLS when control requires client auth
EXECUTOR_GRPC_TLS_CERT_FILE=
EXECUTOR_GRPC_TLS_KEY_FILE=

# Must match control side EXECUTION_CALLBACK_KEY exactly
EXECUTION_CALLBACK_KEY=replace-with-long-random-shared-key

# Executor local settings
EXECUTOR_HTTP_PORT=4280
EXECUTOR_DB_PATH=/data/executor.db
EXECUTOR_WORKDIR=/data/workdir
EXECUTOR_TASK_TIMEOUT_SECONDS=1800
EXECUTOR_QUEUE=default
